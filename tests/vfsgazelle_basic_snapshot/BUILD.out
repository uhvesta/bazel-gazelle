load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "vfsgazelle_basic_snapshot",
    srcs = ["hello.go"],
    importpath = "example.com/vfsgazelle_basic_snapshot",
    visibility = ["//visibility:public"],
)

go_test(
    name = "vfsgazelle_basic_snapshot_test",
    srcs = ["hello_test.go"],
    embed = [":vfsgazelle_basic_snapshot"],
)
